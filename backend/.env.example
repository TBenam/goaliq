# ==============================================
# GoalIQ Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ==============================================

# ---- Serveur ----
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# ---- API-Football (https://api-football.com) ----
# Plan Free = 100 req/jour | Pro = 7500 req/jour
API_FOOTBALL_KEY=VOTRE_CLE_API_FOOTBALL_ICI

# ---- Groq (https://console.groq.com) ----
# Gratuit jusqu'à 14 400 req/jour sur llama-3.3-70b
GROQ_API_KEY=gsk_VOTRE_CLE_GROQ_ICI

# ---- The Odds API (https://the-odds-api.com) ----
# Optional — Pour les cotes réelles des bookmakers
# Plan Free = 500 req/mois
ODDS_API_KEY=VOTRE_CLE_ODDS_ICI

# ---- Firebase Admin SDK ----
# Coller le contenu JSON du fichier Service Account ici (en une seule ligne échappée)
# Depuis Firebase Console → Paramètres Projet → Comptes de service → Générer une nouvelle clé privée
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"VOTRE_PROJECT_ID","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}

# ---- Firebase Project ----
FIREBASE_PROJECT_ID=VOTRE_PROJECT_ID
FIREBASE_DATABASE_URL=https://VOTRE_PROJECT_ID-default-rtdb.firebaseio.com

# ---- Push Notifications (VAPID) ----
# Générer avec: node -e "const wp = require('web-push'); const keys = wp.generateVAPIDKeys(); console.log(JSON.stringify(keys))"
VAPID_PUBLIC_KEY=VOTRE_CLE_PUBLIQUE_VAPID
VAPID_PRIVATE_KEY=VOTRE_CLE_PRIVEE_VAPID
VAPID_SUBJECT=mailto:goaliq@votre-domaine.com

# ---- Admin ----
# Clé secrète pour les endpoints admin (génération de codes VIP, etc.)
ADMIN_SECRET_KEY=goaliq-admin-super-secret-key-CHANGER-EN-PROD
